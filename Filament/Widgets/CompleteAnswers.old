/**
 * Undocumented class
 *
 * @property array $filters
 */
class CompleteAnswers extends BaseWidget
{
    use InteractsWithTable;
    use InteractsWithPageFilters;
    // use HasXotTable;

    protected int | string | array $columnSpan = 'full';

    public function table(Table $table): Table
    {
        return $table
            ->query($this->getTableQuery())
            ->columns($this->getTableColumns())
            ->headerActions($this->getTableHeaderActions())
            ->persistFiltersInSession()
            ->extremePaginationLinks()
        ;
    }

    public function populateTrans()
    {
        $transkey = 'limesurvey::lime_survey_'.$this->getSurveyId();
        $trans = trans($transkey);

        if (trans()->has('limesurvey::lime_survey_'.$this->getSurveyId())) {
            if (count($trans) > 50) {
                return;//gia' popolato
            }
        } else {
            $filename = app(GetTransFilenameAction::class)->execute($transkey);
            app(SaveArrayAction::class)->execute([], $filename);
            $trans = [];
        }

        $questions = LimeQuestion::with(['l10n', 'child'])
            ->where('sid', $this->getSurveyId())
            ->get()
            ->pluck('l10n.question', 'fieldname')
            ->toArray()
        ;

        $questions_padri = LimeQuestion::with(['l10n'])
            ->where('sid', $this->getSurveyId())
            ->where('parent_qid', 0)
            ->get()
            ->pluck('l10n.question', 'fieldname')
            ->toArray()
        ;

        // dddx([$questions, $questions_padri]);

        // Per ogni elemento figlio, sostituire il suo valore con quello del padre
        foreach ($questions as $key => $value) {
            foreach ($questions_padri as $padreKey => $padreValue) {
                if (strpos($key, $padreKey) === 0) {
                    if ($questions[$key] !== $padreValue) {
                        $questions[$key] = $padreValue.' '.$questions[$key]; // Sostituisci con il valore del padre
                    } else {
                        $questions[$key] = $padreValue; // Sostituisci con il valore del padre
                    }
                    break; // Una volta trovato il padre, non serve continuare
                }
            }
        }

        // dddx($questions);
        $questions = Arr::mapWithKeys($questions, function (string $item, string $key) {
            return [
                $key => Str::limit($item, 20),
                $key.'answer' => Str::limit($item, 20),
                $key => strip_tags($item),
                $key.'answer' => strip_tags($item),
            ];
        });

        $up = array_merge($trans, $questions);
        $filename = app(GetTransFilenameAction::class)->execute($transkey);

        app(SaveArrayAction::class)->execute($up, $filename);
    }

    public function getXlsFields(): array
    {
        $query = $this->getTableQuery();

        $limeQuestions = LimeQuestion::with(['l10n'])
            ->orderBy('question_order')
            // ->orderBy('title')
            ->where('sid', $this->getSurveyId())
            ->isLeaf()
            ->get();
        // dddx($limeQuestions);
        $tmp = [];
        $priorityFields = ['token', 'attribute_3', 'email'];
        $fields = array_merge($priorityFields, $tmp);
        foreach ($limeQuestions as $question) {
            // dddx($question);
            // if($question->qid == 35378 || $question->parent_qid == 35378){
            //     dddx($question);
            // }

            // if($question->fieldname == '955466X1143X34111'){
            //     dddx($question);
            // }

            if (! in_array($question->parent_qid, ['0', 0])) {
                if (in_array($question->type, ['!'])) {
                    // dddx($question);
                    $fields[$question->parent->title] = $question->fieldname.'answer';
                }
                if (in_array($question->type, ['M'])) {
                    // dddx($question);
                    $fields[$question->parent->title] = $question->fieldname.'answer';
                } else {
                    $fields[$question->parent->title] = $question->fieldname;
                }
                if (in_array($question->type, ['T', 'S'])) {
                    $fields[$question->parent->title] = $question->fieldname.'answer';
                }
            } else {
                // if($question->fieldname == '955466X1143X34111'){
                //     dddx($question);
                // }
                if (in_array($question->type, ['T', 'S'])) {
                    $fields[$question->title] = $question->fieldname;
                } else {
                    $fields[$question->title] = $question->fieldname.'answer';
                }
                // $fields[] = $question->fieldname.'answer';
            }
        }
        // dddx([$tmp, $query->first()->toArray()]);
        // dddx([
        //     $limeQuestions,
        //     $fields
        // ]);

        // Separare i primi tre elementi dagli altri
        $fixed = array_slice($fields, 0, 3, true); // Prende solo le chiavi 0, 1, 2
        $toSort = array_slice($fields, 3, null, true); // Prende gli altri elementi

        // Ordinare alfabeticamente gli elementi per chiave
        ksort($toSort);

        // Unire i due array
        return $fixed + $toSort;
    }

    public function getGroups(): array
    {
        return LimeGroup::where('sid', $this->getSurveyId())
            ->with('labels')
            ->get()
            ->pluck('labels.group_name', 'gid')
            ->all()
        ;
    }

    public function getSurvey(): SurveyPdf
    {
        $survey_pdf_id = Arr::get($this->filters ?? [], 'survey_pdf_id', null);
        $survey_pdf = SurveyPdf::with(['questionCharts', 'questionCharts.extra'])
            ->firstWhere(['id' => $survey_pdf_id]);
        Assert::notNull($survey_pdf);
        return $survey_pdf;
    }

    public function getSurveyId(): string
    {
        $survey_pdf = $this->getSurvey();
        Assert::notNull($survey_pdf->survey_id);
        return $survey_pdf->survey_id;
    }

    public function getTableQuery(): \Illuminate\Database\Eloquent\Builder|\Illuminate\Database\Eloquent\Relations\Relation|null
    {
        $survey_response = SurveyResponse::getResponsesForSurvey($this->getSurveyId());

        Assert::isArray($this->filters);
        $filter_data = DashboardFilterData::from($this->filters);

        $query = $survey_response
            ->withParticipants()
            ->where('submitdate', '!=', null)
            ->ofDashboardFilterData($filter_data);
        $query->addSelect('*');

        $questions = $this->getQuestions();

        foreach ($questions as $q) {
            Assert::isInstanceOf($q, LimeQuestion::class, '['.__LINE__.']['.class_basename(self::class).']');
            $main = $q->qid;

            if ($q->parent_qid !== 0) {
                $main = $q->parent_qid;
            }

            $query = $query->withAnswersLabel($main, $q->fieldName, $q->fieldName, 'subquery');
        }

        return $query;
    }

    public function getQuestions(): Collection
    {
        $questions = LimeQuestion::where('sid', $this->getSurveyId())
                //->where('parent_qid', 0)
            ->whereNotIn('type', ['X'])
            ->orderBy('question_order')
            ->isLeaf()
        ;
        Assert::isArray($this->filters, '['.__LINE__.']['.class_basename(self::class).']');
        if (isset($this->filters['group'])) {
            $questions = $questions->where('gid', $this->filters['group']);
        }

        return $questions->get()
            ->sortBy(function ($item) {
                Assert::notNull($item->group, '['.__LINE__.']['.class_basename(self::class).']');
                return $item->group->group_order * 1000 + $item->question_order;
            });
    }

    public function getRootQuestions(): Collection
    {
        $root_questions = LimeQuestion::where('sid', $this->getSurveyId())
            ->where('parent_qid', 0)
            ->whereNotIn('type', ['X']);
        Assert::isArray($this->filters, '['.__LINE__.']['.class_basename(self::class).']');
        if (isset($this->filters['group'])) {
            $root_questions = $root_questions->where('gid', $this->filters['group']);
        }

        return $root_questions->get()
            ->sortBy(function ($item) {
                Assert::notNull($item->group, '['.__LINE__.']['.class_basename(self::class).']');
                return $item->group->group_order * 1000 + $item->question_order;
            });
    }

    public function getFilterField(): string|null
    {
        $survey_pdf = $this->getSurvey();

        $limeSurvey = $survey_pdf->info;
        if ($limeSurvey === null) {
            return null;
        }
        $limeQuestion = $limeSurvey->questions->where('qid', $survey_pdf->question_filter)->first();
        if ($limeQuestion === null) {
            return null;
        }

        $gid = $limeQuestion->gid;
        return $survey_pdf->survey_id.'X'.$gid.'X'.$survey_pdf->question_filter;
    }

    protected function getTableHeaderActions(): array
    {
        return [
                // ExportAction::make()
                //     ->label('')
                //     ->icon('fas-file-excel')
                //     ->exporter(AnswersCompleteExporter::class)
                //     ->chunkSize(100000),
            Action::make('export-table-xls')
                ->label('')
                ->icon('fas-file-excel')
                ->action(function () {
                    $fields = $this->getXlsFields();
                    $query = $this->getTableQuery();
                    // dddx($query->get()->take(5));
                    // $fields = $this->getXlsFields();
                    // $transkey = 'limesurvey::lime_survey_'.$this->getSurveyId();
                    $transkey = "limesurvey::lime_survey_{$this->getSurveyId()}";
                    // dddx([
                    //     'query' => $query->first(),
                    //     '$fields' => $fields,
                    //     'transkey' => $transkey,
                    // ]);

                    $this->populateTrans();
                    $filename = class_basename($this).'_'.$this->getSurvey()->name.'.xlsx';
                    return (new QueryExport($query, $transkey, $fields))
                        ->download($filename);
                }),
        ];
    }

    protected function getTableColumns(): array
    {
        $columns = [
            Tables\Columns\TextColumn::make('_id')
                ->label('ID')
                ->sortable()
                //->default(fn ($record) => dddx($record))
                ,
            //Tables\Columns\TextColumn::make('submitdate')
                //->description('Your full name here, including any middle names.'),
            //Tables\Columns\TextColumn::make('completed'),
            //Tables\Columns\TextColumn::make('sent'),
            //Stack::make([
            GroupColumn::make('user')->schema([
                Tables\Columns\TextColumn::make('submitdate'),
                Tables\Columns\TextColumn::make('firstname'),
                Tables\Columns\TextColumn::make('lastname'),
                Tables\Columns\TextColumn::make('email')->searchable(),
                Tables\Columns\TextColumn::make('language'),
                Tables\Columns\TextColumn::make('token'),
            ]),

                //->label('Data Invio')
                //->dateTime('d-m-Y')
                //->sortable(),
            // Aggiungi altre colonne se necessario
        ];

        $attrs = [];
        for ($i = 1;$i <= 6;$i++) {
            $attrs[] = Tables\Columns\TextColumn::make('attribute_'.$i);
        }

        $columns[] = GroupColumn::make('attributes')->schema($attrs);

        foreach ($this->getRootQuestions() as $q) {
            Assert::isInstanceOf($q, LimeQuestion::class, '['.__LINE__.']['.class_basename(self::class).']');

            /** @var string */
            $label = $q->question;

            //$label = utf8_decode($label);
            //$label = mb_convert_encoding($label, mb_detect_encoding($label), 'UTF-8');
            // Converti nuovamente il testo in UTF-8
            //$label = mb_convert_encoding($label, 'UTF-8', 'ISO-8859-1');
            //$label = html_entity_decode($label, ENT_QUOTES, 'UTF-8');
            //$label = '['.$q->group->group_order.']['.$q->question_order.']'.$label;//4 debug
            //$label = 'type:['.$q->type.']qid:['.$q->qid.']sons:['.$q->children->count().']'.$label;// 4 debug
            $label = strip_tags($label);
            $label = Str::limit($label, 150);

            if ($q->children->count() === 0) {
                $columns[] = Tables\Columns\TextColumn::make($q->field_name)
                    ->label($label)
                    ->wrapHeader()
                    ->verticallyAlignStart()
                    ->grow()
                    ->wrap()
                    ->formatStateUsing(function ($record) use ($q) {
                        $msg = '['.$record->getAttribute($q->field_name).'] '.$record->getAttribute($q->field_name.'answer');
                        Assert::string(mb_detect_encoding($msg));
                        return mb_convert_encoding($msg, mb_detect_encoding($msg), 'UTF-8');
                    });
            } else {
                $sub = [];
                foreach ($q->children as $child) {
                    $sub[] = Tables\Columns\TextColumn::make($child->field_name.'a')
                        ->label($label)
                        ->wrapHeader()
                        ->verticallyAlignStart()
                        ->grow()
                        ->wrap()

                    // ->formatStateUsing(function ($record) use ($child) {

                    //     $msg = '['.$record->getAttribute($child->field_name).'] '.$record->getAttribute($child->field_name.'answer');
                    //     $msg = mb_convert_encoding($msg, mb_detect_encoding($msg), 'UTF-8');
                    //     return $msg;

                    //     return 'pippo';
                    // })
                        ->default(function ($record) use ($child) {
                            Assert::string($child->question);
                            $answer = $record->getAttribute($child->field_name.'answer');
                            if ($answer === '') {
                                return '';
                            }
                            $msg = '['.$record->getAttribute($child->field_name).'] '.PHP_EOL;
                            $msg .= $child->question.'  :'.PHP_EOL;
                            $msg .= $answer;
                            Assert::string(mb_detect_encoding($msg));
                            return mb_convert_encoding($msg, mb_detect_encoding($msg), 'UTF-8');
                        })
                        ->limit(50)
                    //->tooltip('aaa')
                    ;
                }
                $columns[] = GroupColumn::make($q->field_name)
                    ->label($label)
                    ->wrapHeader()
                    ->verticallyAlignStart()
                    ->grow()
                    ->schema($sub);
            }
        }

        return $columns;
    }
}
