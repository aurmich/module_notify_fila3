    protected static ?string $navigationLabel = 'Alert';
    protected static ?string $title = 'Alert';

    public function getQuestions(): Collection
    {
        return LimeQuestion::where('sid', $this->survey_id)
            ->where('parent_qid', 0)
            //->whereNotIn('type', [ 'M', 'F' ])
            // ->whereIn('type', ['B', '!','F'])
            // ->whereIn('type', ['B'])
            ->whereIn('type', ['F'])
            // ->whereIn('type', ['L','!','R','F','1','H','O'])
            // ->whereIn('type', ['L','!','R','1','H','O'])
            // ->whereIn('type', ['!'])
            ->get()
            // ->take(5) //MariaDB can only use 61 tables in a join
        ;
    }

    public function getTableQuery(): Builder
    {
        $query = parent::getTableQuery();

        // dddx($this->questions);

        foreach ($this->questions as $key => $q) {
            if ($q->children->count() > 0) {
                foreach ($q->children as $child) {
                    // $query = $query->where($child->fieldName.'ask_lang.answer', '<=', 6);

                    $query = $query->where(function ($subQuery) use ($child) {
                        $subQuery->where($child->fieldName.'ask_lang.answer', '<=', 6)
                            ->orWhereNull($child->fieldName.'ask_lang.answer'); // Controlla se è NULL
                    });

                    // $query = $query->where(function ($subQuery) use ($child) {
                    //     $subQuery->whereBetween($child->fieldName.'ask_lang.answer', [0, 10])  // Filtra valori tra 0 e 10
