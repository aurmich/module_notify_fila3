                    // });
                }
            }
            // dddx([
                //     $q,
                //     $q->fieldName,
            // ]);

            // $query = $query->where(function ($subQuery) use ($q) {
                //     $subQuery->where($q->fieldName.'ask_lang.answer', '<=', 6)
                //         ->orWhereNull($q->fieldName.'ask_lang.answer'); // Controlla se è NULL
            // });

            // if (! in_array($q->type, ['L','!','R','F','1','H','O'])) { //LISTA non TRADUCIBILI
            // dddx([
                    //     $q,
                    //     $q->fieldName,
            // ]);
            // $query = $query->where(function ($subQuery) use ($q) {
                    //     $subQuery->where($q->fieldName.'ask_lang.answer', '<=', 6)
