<?php


declare(strict_types=1);

namespace Modules\Quaeris\Filament\Pages;

use Filament\Forms;
use Filament\Forms\Get;
use Filament\Forms\Form;
use Filament\Pages\Page;
use Filament\Actions\Action;
use Webmozart\Assert\Assert;
use Filament\Forms\Components\Radio;
use Modules\Quaeris\Models\SurveyPdf;
use Filament\Forms\Contracts\HasForms;
use Filament\Forms\Components\TextInput;
use Filament\Forms\Components\DatePicker;
use Modules\Quaeris\Datas\AnswersFilterData;
use Filament\Forms\Concerns\InteractsWithForms;
use Modules\Quaeris\Actions\SurveyPdf\ExportTypeAction;

class Exports extends Page implements HasForms
{
    use InteractsWithForms;

    protected static ?string $navigationIcon = 'heroicon-o-document';
    protected static string $view = 'quaeris::filament.pages.exports';
    protected static ?int $navigationSort = 16;
    protected static ?string $title = 'Exports';

    public ?array $data = [];

    public function mount(): void
    {
        $this->form->fill();
        // $this->form->fill([auth()->user()->name]);
    }

    public function form(Form $form): Form
    {
        return $form
            ->schema([
                DatePicker::make('startDate')
                    ->maxDate(static fn (Get $get) => $get('endDate') ?: now())
                    ->displayFormat('d/m/Y')
                    // ->native(false)
                    ->stateBindingModifiers(['defer'])
                    ,
                DatePicker::make('endDate')
                    ->displayFormat('d/m/Y')
                    // ->maxDate(fn (Get $get) => $get('endDate') ?: now())
                    ->displayFormat('d/m/Y')
                    ->stateBindingModifiers(['defer'])
                    ,
                // ->native(false)


                Radio::make('type')
                    ->label('Seleziona cosa vuoi esportare')
                    ->options(static fn (): array => [
                        'xls_alert' => 'Lista feedback valutazione <6', // lista feedback valutazione <6
                        // 'xls_alert_user' => 'xls_alert_user', // lista feedback valutazione <6 per riga di domanda
                        'xls_alert_user2' => 'Lista feedback valutazione <6 per riga di domanda', // lista feedback valutazione <6 per riga di domanda
                        // 'xls_alert_user_all_answers' => 'xls_alert_user_all_answers', // lista feedback per riga di domanda
                        'xls_answers_complete' => 'Lista risposte complete', // select *
                        'xls_optout' => 'Lista disiscritti', // lista disiscritti
                        'xls_contact_list' => 'Lista contatti inseriti', // lista contatti inseriti
                        'pdf' => 'Pdf',
                    ])
                    ->descriptions([
                        'xls_alert' => 'Dell\'ultimo mese',
                        'xls_alert_user2' => 'Dell\'ultimo mese',
                        'xls_answers_complete' => 'Dell\'ultimo mese',
                        'xls_optout' => 'Dell\'ultimo mese',
                        'xls_contact_list' => 'Dell\'ultimo mese',
                        'pdf' => 'Versione pdf, per intervallo di tempo selezionato',
                    ])
                    ->required()
                    ->columns(3)
                    ->validationMessages([
                        'required' => 'Devi selezionare un opzione',
                    ]),
            ])
            ->statePath('data')
            ;
    }

    protected function getFormActions(): array
    {
        return [
            Action::make('save')

                ->submit('save'),
        ];
    }

    public function save() //: void
    {
        // dddx($this->data);

        if (null !== $this->data['type']) {
            $answersFilterData = AnswersFilterData::from([
                'date_from' => $this->data['startDate'],
                'date_to' => $this->data['endDate'],
                // 'question_id' => $livewire->filters[''],
                // 'question_filter' => $livewire->filters['question_filter'],
            ]);
            dddx($answersFilterData);
            Assert::isInstanceOf($surveyPdf = SurveyPdf::find($this->data['survey_pdf_id']), SurveyPdf::class);

            return app(ExportTypeAction::class)->execute($surveyPdf, $data['type'], $answersFilterData);
        }


        // Notification::make()
        // ->success()
        // ->title(__('filament-panels::resources/pages/edit-record.notifications.saved.title'))
        // ->send();
    }
}
