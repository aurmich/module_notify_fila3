    public static function getModel(): string
    {
        $uri = request()->capture()->getUri();
        //dddx($_SERVER);
        //dddx(request()->capture()->getUri());//https://manager2.quaerisofficina.it/quaeris/admin/dashboard-one
        //dddx(request()->route()->getName());
        //dddx(get_defined_vars());
        //dddx(self::getBreadcrumb());//va in 503
        //dddx(config('xra.dashboard'));
        if (Str::contains($uri, 'dashboard-one')) {
            return QuestionChart::class; //se dashboard-one
        }

        if (Str::contains($uri, 'dashboard')) {
            return QuestionChart::class; //se dashboard-one
        }

        return QuestionChartTmp::class; //altrove
    }

