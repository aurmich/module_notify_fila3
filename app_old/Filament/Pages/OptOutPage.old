<?php

namespace Modules\Quaeris\Filament\Pages;

use Filament\Forms\Components\DatePicker;
use Filament\Pages\Page;
use Filament\Tables;
use Filament\Tables\Concerns\InteractsWithTable;
use Filament\Tables\Contracts\HasTable;
use Filament\Tables\Enums\FiltersLayout;
use Filament\Tables\Table;
use Illuminate\Database\Eloquent\Builder;
use Modules\Limesurvey\Models\TokensResponse;

class OptOutPage extends Page implements HasTable
{
    use InteractsWithTable;

    protected static ?string $navigationIcon = 'heroicon-o-document-text';
    protected static string $view = 'quaeris::filament.pages.opt-out';

    protected static ?string $navigationGroup = 'Esportazioni';
    protected static ?string $navigationLabel = 'OptOut';

    // Configura il titolo della pagina
    protected static ?string $title = 'Tokens con Email OptOut';

    public function getTableQuery(): Builder
    {
        // Query personalizzata: seleziona tutti i tokens con emailstatus = OptOut
        $survey_id = '946595';
        return TokensResponse::getResponsesForSurvey($survey_id)
            ->where('emailstatus', 'OptOut');
    }

    public function table(Table $table): Table
    {
        return $table
            ->query($this->getTableQuery())
            ->columns($this->getTableColumns())
            ->filters($this->getTableFilters())
            ->filtersLayout(FiltersLayout::AboveContent)
            ->actions($this->getTableActions())
            ->bulkActions($this->getTableBulkActions());
    }

    protected function getTableColumns(): array
    {
        return [
            Tables\Columns\TextColumn::make('id')
                ->label('ID')
                ->sortable(),
            Tables\Columns\TextColumn::make('emailstatus')
                ->label('Email Status')
                ->sortable(),
            Tables\Columns\TextColumn::make('sent')
                ->label('Data Invio')
                ->dateTime('d-m-Y')
                ->sortable(),
            // Aggiungi altre colonne se necessario
        ];
    }

    protected function getTableFilters(): array
    {
        return [
            Tables\Filters\Filter::make('sent')
                ->form([
                    DatePicker::make('sent_from')
                        ->label('Inviato da'),
                    DatePicker::make('sent_until')
                        ->label('Inviato fino a'),
                ])
                ->query(function (Builder $query, array $data) {
                    return $query
                        ->when($data['sent_from'], fn ($q, $date) => $q->whereDate('sent', '>=', $date))
                        ->when($data['sent_until'], fn ($q, $date) => $q->whereDate('sent', '<=', $date));
                }),
        ];
    }

    protected function getTableActions(): array
    {
        return [
            // Definisci eventuali azioni aggiuntive, come visualizzare o modificare i record
        ];
    }

    protected function getTableBulkActions(): array
    {
        return [
            // Definisci eventuali azioni collettive sui record selezionati
        ];
    }
}
