<?php

namespace Modules\Limesurvey\Actions;

use Webmozart\Assert\Assert;
use Modules\Limesurvey\Models\LimeQuestion;
use Modules\Limesurvey\Models\SurveyResponse;
use Modules\Limesurvey\Models\SurveyFlipResponse;

//use Modules\Limesurvey\Models\LimeSurvey;

class PopulateSurveyFlipBySurveyIdAction
{
    public function execute(string $survey_id): void
    {

        $survey_response = SurveyResponse::getResponsesForSurvey($survey_id);

        $tbl = $survey_response->getTable();
        $fields = $survey_response->getConnection()->getSchemaBuilder()->getColumnListing($tbl);
        $fields = array_slice($fields, 9);
        $questions = LimeQuestion::where('sid', $survey_id)
                // ->whereNotIn('type', ['X'])
                // ->orderBy('question_order')
                ->isLeaf()->get();

        /*
        $q_fields=$questions->pluck('fieldName')->toArray();
        dddx(
            [
                'table'=>$tbl,
                'fields'=>$fields,
                'q_fields'=>$q_fields,
                'add'=>array_diff($fields,$q_fields),
                'sub'=>array_diff($q_fields,$fields),
            ]
        );
        */
        $query = $survey_response
            ->withParticipants()
            ->where('submitdate', '!=', null)
        ;
        $query->addSelect('*');
        $rows = $query; //->get();

        // foreach ($questions as $q) {
        //     if ($q->parent_qid === 0) {
        //         $query = $query->withAnswersLabel($q->parent_qid, $q->fieldName, $q->fieldName, 'subquery');
        //     } else {
        //         $query = $query->withAnswersLabel($q->qid, $q->fieldName, $q->fieldName, 'subquery');
        //     }
        // }

        foreach ($questions as $q) {
            Assert::isInstanceOf($q, LimeQuestion::class, '['.__LINE__.']['.class_basename(self::class).']');
            $main = $q->qid;

            if ($q->parent_qid !== 0) {
                $main = $q->parent_qid;
            }

            $query = $query->withAnswersLabel($main, $q->fieldName, $q->fieldName, 'subquery');
        }

        $rows = $query->get();
        // dddx($rows->get()->take(5));

        $questions_data = [];
        foreach ($questions as $q) {
            if ($q->children->count() > 0) {
                foreach ($q->children as $child) {
                    $item = [
                        'q.id' => $q->id,
                        'child.id' => $child->id,
                        'field_name' => $child->fieldName,
                        'title' => strip_tags($child->getFullTitle()),
                        'question_type' => $q->type,
                        'child_type' => $child->type,
                        'children' => $q->children->count(),
                        'child_children' => $child->children->count(),
                    ];
                    $questions_data[] = $item;
                }
            } else {
                $item = [
                    'q.id' => $q->qid,
                    'field_name' => $q->fieldName,
                    'title' => strip_tags($q->getFullTitle()),
                    'question_type' => $q->type,
                    'children' => $q->children->count(),
                ];
                $questions_data[] = $item;
            }
        }

        // dddx([$rows->take(5), $questions_data, $rows->max('id')]);

        // $old_id = SurveyFlipResponse::max('old_id');
        // if($old_id == null){
        //     $rows = $query->get();
        // }else{
        //     $rows = $query->where('id', '>', $old_id)->get();
        // }

        foreach ($rows as $row) {
            // dddx($row);
            foreach ($questions_data as $question_data) {
                // dddx([$row, $question_data]);
                // if($question_data['q.id'] == 48872){
                //     dddx([$row, $question_data]);
                // }

                if ($question_data['children'] == 0) {
                    $answer = $row->{$question_data['field_name']};
                    if (in_array($question_data['question_type'], ['!'])) {
                        $answer = $row->{$question_data['field_name'].'answer'};
                    }
                    if (in_array($question_data['question_type'], ['M'])) {
                        $answer = $row->{$question_data['field_name'].'answer'};
                    }
                    if (in_array($question_data['question_type'], ['T', 'S', 'L'])) {
                        $answer = $row->{$question_data['field_name'].'answer'};
                    }
                } else {
                    if (in_array($question_data['question_type'], ['T', 'S'])) {
                        $answer = $row->{$question_data['field_name']};
                    } else {
                        $answer = $row->{$question_data['field_name'].'answer'};
                    }
                }



                $data = [
                    'survey_id' => $survey_id,
                    'question_id' => $question_data['q.id'],
                    'question_type' => $question_data['question_type'],
                    'token' => $row->token,
                    // 'answer' => $row->{$question_data['field_name'].'answer'},
                    'answer' => $answer ?? 'nessuna risposta',
                    'value' => $row->{$question_data['field_name']} ?? 'nessuna risposta',
                    'submitdate' => $row->submitdate,
                    'fieldname' => $question_data['title'],
                    'old_id' => $row->tid,
                ];

                // dddx($data);

                SurveyFlipResponse::firstOrCreate(
                    $data
                );
            }
        }
    }
}
