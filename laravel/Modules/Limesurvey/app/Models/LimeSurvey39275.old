    // Scopes...

    public function scopewithAnswersLabel(Builder $builder, string $qid, string $field_name): Builder
    {
        $ask_table = 'lime_answers';
        $ask_table_lang = 'lime_answer_l10ns';

        return $builder/* ->selectRaw('*,ask_lang.answer as label') */
            ->join(
                $ask_table.' as ask',
                static function ($join) use ($qid, $field_name): void {
                    $join->on('ask.code', '=', $field_name)
                        ->whereRaw('ask.qid = "'.$qid.'"');
                }
            )->join(
                $ask_table_lang.' as ask_lang',
                static function ($join): void {
                    $join->on('ask.aid', '=', 'ask_lang.aid')
                        ->whereRaw('ask_lang.language="it"');
                }
            );
    }

