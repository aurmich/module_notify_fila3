{
    "name": "quaeris-tv/module_limesurvey_fila3",
    "description": "limesurvey module dedicated to limesurvey software for laravel",
    "keywords": [
        "laraxot",
        "laravel",
        "module_limesurvey",
        "Laravel",
        "Limesurvey"
    ],
    "homepage": "https://github.com/quaeris-tv/module_limesurvey_fila3.git",
    "license": "MIT",
    "authors": [{
        "name": "Marco Sottana",
        "email": "marco.sottana@gmail.com"
    }],
    "extra": {
        "laravel": {
            "providers": [],
            "aliases": {

            }
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\Limesurvey\\": "app/"
        }
    },
    "require_comment": {
        "thecodingmachine/safe": "^2.5"
    },
    "require-dev_comment": {
        "psalm/plugin-laravel": "^2.8",
        "thecodingmachine/phpstan-safe-rule": "^1.2",
        "laravel/pint": "^1.13",
        "driftingly/rector-laravel": "^0.26.2",
        "symplify/phpstan-rules": "*",
        "nunomaduro/phpinsights": "^2.9",
        "larastan/larastan": "*",
        "vimeo/psalm": "^5.15",
        "enlightn/enlightn": "^2.5"
    },
    "repositories_comment": [ {
        "type": "path",
        "url": "../Xot"
    },
    {
        "type": "path",
        "url": "../Tenant"
    },
    {
        "type": "path",
        "url": "../UI"
    }],
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "nunomaduro/phpinsights": "^2.11"
    }
}
