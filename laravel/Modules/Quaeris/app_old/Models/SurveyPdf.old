class SurveyPdf extends BaseModel implements HasMedia
{
    use HasChartTrait;
    use InteractsWithMedia;

    protected $fillable = [
        'survey_id',
        'customer_id', 'name',
        'pdf_view', 'logo',
        // 'chart_color',
        // 'chart_font_family',
        // 'chart_font_style',
        // 'chart_font_size',
        'date_from', 'date_to',
        'title',
        'subtitle',
        'xls_field_1',
        'xls_field_2',
        'xls_field_3',
        'xls_field_4',
        'xls_field_5',
        'question_contact_email',
        'chart_engine',
        'question_filter',
        'question_filter_txt',
        'allow_multiple_invite',
        'xls_field_json',
    ];

    /** @var array<string, string> */
    protected $casts = [
        // 'date_from' => 'datetime:d/m/Y', // da verificare
        // 'date_to' => 'datetime:d/m/Y', // da verificare
        'xls_field_json' => 'array',
        'survey_id' => 'string',
        'published_at' => 'datetime',
        'created_at' => 'datetime',
        'updated_at' => 'datetime',
    ];

    /** @var list<string> */
    protected $with = [
        'extra',
    ];

    // ---------- relationships

    public function questionCharts(): HasMany
    {
        return $this->hasMany(QuestionChart::class);
    }

    public function questions(): HasMany
    {
        return $this->hasMany(LimeQuestion::class, 'sid', 'survey_id');
    }

    public function contacts(): HasMany
    {
        return $this->hasMany(Contact::class);
    }

    // public function duocircles(): HasMany {
    //     return $this->hasMany(Duocircle::class);
    // }

    public function notifyThemes(): MorphMany
    {
        return $this->morphMany(NotifyTheme::class, 'post');
    }

    public function customer(): BelongsTo
    {
        return $this->belongsTo(Customer::class);
    }

    /**
     * @return MorphOne ;
     */
    public function pdfStyle(): MorphOne
    {
        return $this->morphOne(PdfStyle::class, 'style')// ;
            ->withDefault([
                'backtop' => '35',
                'backbottom' => '14',
                'backleft' => '2',
                'backright' => '2',
                'x_label_angle' => '0',
                'font_size_question' => '100',
            ]);
    }

    /*
    public function info():HasOne {
        return $this->hasOne(LimeSurvey::class,'sid','survey_id');
    }
    */

    public function info(): BelongsTo
    {
        return $this->belongsTo(LimeSurvey::class, 'survey_id', 'sid');
    }

    // public function answers(){

    // }

    public function scopeActive(Builder $builder): Builder
    {
        return $builder->whereHas('info', static function ($item): void {
            $item->where('active', '!=', 'N');
        });
    }

    public function getInfo(): LimeSurvey
    {
        // return LimeSurvey::firstWhere('sid', $this->survey_id);

        // $lime_survey = LimeSurvey::firstWhere('sid', $this->survey_id);
        $lime_survey = LimeSurvey::with(['lang', 'questions'])
            ->where('active', 'Y')
            ->firstWhere('sid', $this->survey_id);
        if ($lime_survey === null) {
            throw new \Exception('['.__LINE__.']['.class_basename(self::class).']');
        }

        return $lime_survey;
    }

    public function surveylsTitle(): string
    {
        Assert::string($res = $this->getInfo()->lang?->surveyls_title, 'wip');

        return $res;
    }

    public function getLogoAttribute(?string $value): ?string
    {
        // return $this->getMedia()->first()->getUrl();
        // dd($this->getMedia()->first()->getUrl());
        return $this->getFirstMediaUrl();
    }

    /**
     * @param string|null $value
     */
    public function getDateFromAttribute($value): ?string
    {
        if ($value === '0000-00-00') {
            return null;
        }

        return $value;
    }

    /**
     * @param string|null $value
     */
    public function getDateToAttribute($value): ?string
    {
        if ($value === '0000-00-00') {
            return null;
        }

        return $value;
    }

    public function getXlsFieldJsonAttribute(string|array|null $value): array
    {
        if (\is_array($value)) {
            return $value;
        }

        if ($this->xls_field_1 === '') {
            // dddx($value);
            return [];
        }
        if ($this->xls_field_1 === null) {
            // dddx($value);
            return [];
        }

        return explode(',', $this->xls_field_1);
    }

    public function optionsQuestions(): array
    {
        $options = $this->questions;

        if ($options->isEmpty()) {
            return [];
        }

        $callable = function ($item) {
            Assert::string($question = $item->question);

            return [
                'id' => $item->qid,
                'key' => $item->qid,
                'slug' => $item->title,
                'label' => $item->qid.']'.(string) $item->title.']'.strip_tags($question),
                'parent_id' => $item->parent_qid,
                'pos' => $item->qid,
            ];
        };

        $options = $options->map($callable);

        $grouped = $options->groupBy('parent_id');
        if (! isset($grouped[0])) {
            throw new \Exception('['.__LINE__.']['.class_basename(self::class).']');
        }

        $data = $grouped[0]->map(function (array $item) use ($grouped) {
            $item['sons'] = $grouped->get($item['id'], []);

            return $item;
        });

        $callback = function (array $item) {
            $item['key'] = (string) $item['slug'];
            $item['sons'] = collect($item['sons'])
                ->map(
                    /**
                     * @param array{id: int, key: string, slug: string, label: string, parent_id: int, pos: int, sons: array} $son
                     */
                    function (array $son) use ($item) {
                        $son['key'] = (string) $item['slug'].'['.(string) $son['slug'].']';

                        return $son;
                    }
                )->all();

            return $item;
        };

        return $data->map($callback)->all();

        // Undefined variable $item

        // $callback = function (array $son) use ($item) {
        //     $son['key'] = (string) $item['slug'].'['.(string) $son['slug'].']';

        //     return $son;
        // };

        // return $data->map(
        //     function (array $item) use ($callback) {
        //         $item['key'] = (string) $item['slug'];
        //         $item['sons'] = collect($item['sons'])
        //             ->map($callback)
        //             ->all();

        //         return $item;
        //     }
        // )->all();
    }

    // public function getContactsGropedBySurveyPdfId(): array
    // {
    //     $day = 'DATE_FORMAT(created_at,"%Y/%m/%d")';
    //     $rows = Contact::where('survey_pdf_id', $this->id)
    //         ->selectRaw($day . ' as day,count(*) as q')
    //         ->groupByRaw($day)
    //         ->orderByRaw($day)
    //         ->get();

    //     return $rows->take(-1)->all();
    // }

    public function answers(): LimeSurveyXXXContract
    {
        $class = LimeSurvey::class.$this->survey_id;

        return app($class);
    }

    /**
     * Create a new factory instance for the model.
     */
    protected static function newFactory(): Factory
    {
        return SurveyPdfFactory::new();
    }
}
