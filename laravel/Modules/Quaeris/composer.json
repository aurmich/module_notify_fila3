{
    "name": "quaeris-tv/module_quaeris_fila3",
    "description": "",
    "homepage": "https://github.com/quaeris-tv/module_quaeris_fila3.git",
    "license": "MIT",
    "authors": [{
        "name": "Marco Sottana",
        "email": "marco.sottana@gmail.com"
    }],
    "extra": {
        "laravel": {
            "providers": [
                "Modules\\Quaeris\\Providers\\QuaerisServiceProvider"
            ],
            "aliases": {}
        }
    },
    "autoload": {
        "psr-4": {
            "Modules\\Quaeris\\": "app/",
            "Modules\\Quaeris\\Database\\Factories\\": "database/factories/",
            "Modules\\Quaeris\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "require": {
        "genealabs/laravel-model-caching": "^11.0",
        "spatie/url": "*",
        "spipu/html2pdf": "*",
        "weberhofer/jsonrpcphp": "*"
    },
    "require_comment": {
        "laraxot/module_user_fila3": "dev-master",
        "laraxot/module_xot_fila3": "dev-master",
        "thecodingmachine/safe": "^2.5"
    },
    "require-dev_comment": {
        "enlightn/enlightn": "^2.5",
        "laravel/pint": "^1.13",
        "nunomaduro/collision": "*",
        "larastan/larastan": "*",
        "nunomaduro/phpinsights": "^2.9",
        "orchestra/testbench": "^9.4",
        "orchestra/testbench-core": "^8.11",
        "pestphp/pest": "*",
        "pestphp/pest-plugin-arch": "*",
        "pestphp/pest-plugin-laravel": "*",
        "phpstan/phpstan-deprecation-rules": "*",
        "phpstan/phpstan-phpunit": "*",
        "psalm/plugin-laravel": "^2.8",
        "spatie/laravel-ray": "*",
        "symplify/phpstan-rules": "*",
        "thecodingmachine/phpstan-safe-rule": "^1.2",
        "vimeo/psalm": "^5.15"
    },
    "repositories_comment": [
        {
            "type": "path",
            "url": "../Xot"
        },
        {
            "type": "path",
            "url": "../Tenant"
        },
        {
            "type": "path",
            "url": "../UI"
        }
    ],
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "./vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "pestphp/pest-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "nunomaduro/phpinsights": "^2.12"
    }
}
