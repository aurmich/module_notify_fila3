    // -- functions
    public function copySurveyId(string $survey_id): self
    {
        $model_class = LimeSurvey::class.$survey_id;
        if (! class_exists($model_class)) {
            app(GenerateModelByModelClass::class)
                ->setCustomReplaces(['DummyTable' => 'lime_survey_'.$survey_id])
                ->execute($model_class);
        }

        $model = app($model_class);
        $this->setTable($model->getTable());
        $this->fillable = $model->getFillable();

        return $this;
    }

    public function getValueByQuestionProps(Collection $collection, string $field_name): string
    {
        // dddx([$q, $this, $field_name]);
        /*
        $type_question = $q->first()->type;
        dddx([$type_question, $res]);
        */

        return $this->{$field_name};
    }

