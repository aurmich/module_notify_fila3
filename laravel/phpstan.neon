includes:
    - ./vendor/larastan/larastan/extension.neon
    - ./vendor/thecodingmachine/phpstan-safe-rule/phpstan-safe-rule.neon
    - ./vendor/phpstan/phpstan/conf/bleedingEdge.neon

parameters:

    level: max

    paths:
        - ./Modules
        - ./Themes

    ignoreErrors:
        - '#Unsafe usage of new static#'
        - '#PHPDoc tag @mixin contains unknown class #'
        - '#Static call to instance method Nwidart#'
        - '#Access to an undefined property Modules\\Limesurvey#'
        - identifier: missingType.iterableValue
        - identifier: missingType.generics
        - identifier: match.unhandled
        - identifier: trait.unused


    excludePaths:
        - ./*/vendor/*
        - ./*/Tests/*
        - ./*/build/*
        - ./*/docs/*
        - ./*/docs_old/*
        - ./*/Main_files/*
        - ./Modules/Limesurvey/Models/*
        - ./Modules/Limesurvey/Database/*
        - ./Modules/*/rector.php
        - ./Modules/*/phpinsights.php

    bootstrapFiles:
        - ./phpstan_constants.php
        - ./vendor/amenadiel/jpgraph/src/config.inc.php

    scanFiles:
        - ./Modules/Xot/Helpers/Helper.php

    editorUrl: 'vscode://file/%%file%%:%%line%%'

    tmpDir: ./build/phpstan

    checkUnusedViews: false
    checkModelProperties: false
    # checkMissingIterableValueType: false
    # checkGenericClassInNonGenericObjectType: false
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    checkOctaneCompatibility: false
